# ============================================
#  API Keys (fill in your values)
# ============================================

# Groq - Free LLM for the AI intent assistant
# Get a free key at https://console.groq.com/keys
VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# Saber Money Sandbox - Fiat on/off-ramp
# Get keys from Saber representative (AlgoHackSeries 3.0)
VITE_SABER_CLIENT_ID=
VITE_SABER_BASE_URL=https://api.sandbox.saber.money
VITE_SABER_WIDGET_URL=https://app.sandbox.saber.money
# HMAC signing runs in Supabase Edge Function "saber-sign". Set SABER_CLIENT_ID and SABER_CLIENT_SECRET
# in Supabase Dashboard - Edge Functions - saber-sign - Secrets (not in this .env file).

# Supabase - Workflow persistence and dashboard
# Create a free project at https://supabase.com
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Telegram Bot (optional - for Send Telegram notification block)
# VITE_TELEGRAM_BOT_TOKEN=

# Voice Server (optional - for enhanced AI voice conversation)
VITE_VOICE_SERVER_URL=http://localhost:3002
