# Supabase (same credentials as the frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token

# Groq AI (for Telegram intent parsing)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Algorand node (for balance checks)
ALGOD_URL=https://testnet-api.4160.nodely.dev

# Agent config
POLL_INTERVAL_MS=15000

# Web app URL for Telegram deep links (/run_workflow, workflow_build success)
ZUIK_APP_URL=https://zuik.vercel.app
FRONTEND_URL=http://localhost:5173

# ElevenLabs API (for text-to-speech)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Voice Server Configuration
VOICE_SERVER_PORT=3002

# Cloud deployment settings
PORT=3001
NODE_ENV=development

# Telegram webhook (for cloud deployment)
TELEGRAM_WEBHOOK_URL=https://your-app.railway.app/telegram/webhook
